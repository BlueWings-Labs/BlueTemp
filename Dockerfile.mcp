# BlueWings MCP server — HTTP transport for ContextForge / IBM Code Engine
# Build:  docker build -f Dockerfile.mcp -t bluewings-mcp .
# Run:    docker run -p 8080:8080 -e GITHUB_TOKEN=ghp_... bluewings-mcp

FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY github_services.py grok_agent.py api.py ./
COPY github_mcp_server.py ./
COPY dependency_graph/ dependency_graph/
COPY intelligence/ intelligence/

ENV MCP_TRANSPORT=streamable-http \
    MCP_HOST=0.0.0.0 \
    MCP_PORT=8080 \
    MCP_PATH=/mcp

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD python -c "import os,urllib.request; urllib.request.urlopen('http://127.0.0.1:%s/health'%os.getenv('PORT',os.getenv('MCP_PORT','8080')),timeout=3)"

CMD ["python", "github_mcp_server.py", "streamable-http"]
